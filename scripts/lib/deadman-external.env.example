# Optional external missed-ping monitor for the control-node dead-man.
#
# Copy to ~/.config/grimnir/deadman-external.env, set mode 0600, and insert
# the provider-generated HTTPS ping URL. Treat that URL as a bearer secret.
# Never commit the populated file or paste its value into logs/tickets.
CONTROL_NODE_DEADMAN_EXTERNAL_HEARTBEAT_URL=
